asn_1 = ((1) ->("Behavioral#behavioral: action 'test_1 <= input_0';") (behavioral.test_1 = input_0)),
asn_2 = ((1) ->("Behavioral#behavioral: action 'test_2 <= input_1';") (behavioral.test_2 = input_1)),
v_asn_1 = ((1) ->("P1#p1: action 'Q1 := 10';") (p1.Q1 = 10)),
